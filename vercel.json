{
  "version": 2,
  "outputDirectory": "api",
  "functions": {
    "api/router.php": {
      "runtime": "vercel-php@0.8.0",
      "excludeFiles": [
        "css/**",
        "js/**",
        "images/**",
        "sound/**",
        "json/**",
        "profile/**",
        "request/**"
      ]
    }
  },
  "routes": [
    {
      "src": "/css/(.*)",
      "dest": "/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "/js/$1"
    },
    {
      "src": "/images/(.*)",
      "dest": "/images/$1"
    },
    {
      "src": "/sound/(.*)",
      "dest": "/sound/$1"
    },
    {
      "src": "/json/(.*)",
      "dest": "/json/$1"
    },
    {
      "src": "/profile/(.*)",
      "dest": "/profile/$1"
    },
    {
      "src": "/request/(.*)",
      "dest": "/request/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/api/router.php"
    }
  ]
}
