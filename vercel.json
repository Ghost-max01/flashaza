{
  "version": 2,
  "outputDirectory": ".",
  "functions": {
    "api/router.php": {
      "runtime": "vercel-php@0.8.0"
    }
  },
  "routes": [
    {
      "src": "^/css/(.*)",
      "dest": "/css/$1",
      "continue": true
    },
    {
      "src": "^/js/(.*)",
      "dest": "/js/$1",
      "continue": true
    },
    {
      "src": "^/images/(.*)",
      "dest": "/images/$1",
      "continue": true
    },
    {
      "src": "^/sound/(.*)",
      "dest": "/sound/$1",
      "continue": true
    },
    {
      "src": "^/json/(.*)",
      "dest": "/json/$1",
      "continue": true
    },
    {
      "src": "^/profile/(.*)",
      "dest": "/profile/$1",
      "continue": true
    },
    {
      "src": "^/request/(.*)",
      "dest": "/request/$1",
      "continue": true
    },
    {
      "src": "^/(?!api/)(.*)$",
      "dest": "/api/router.php"
    }
  ]
}
