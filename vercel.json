{
  "version": 2,
  "builds": [
    { "src": "api/router.php", "use": "@vercel/php" },
    { "src": "css/**", "use": "@vercel/static" },
    { "src": "js/**", "use": "@vercel/static" },
    { "src": "images/**", "use": "@vercel/static" },
    { "src": "sound/**", "use": "@vercel/static" },
    { "src": "json/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/css/(.*)", "dest": "/css/$1" },
    { "src": "/js/(.*)", "dest": "/js/$1" },
    { "src": "/images/(.*)", "dest": "/images/$1" },
    { "src": "/sound/(.*)", "dest": "/sound/$1" },
    { "src": "/json/(.*)", "dest": "/json/$1" },
    { "src": "/(.*)", "dest": "/api/router.php" }
  ]
}
